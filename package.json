{
  "name": "memory-palace-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/mobile",
    "dev:mobile": "npm run dev -w apps/mobile",
    "dev:server": "npm run dev -w apps/server",
    "build": "npm run build -w apps/mobile",
    "build:mobile": "npm run build -w apps/mobile",
    "build:server": "npm run build -w apps/server",
    "check:ai-templates": "npm run check:ai-templates -w apps/server",
    "check:content-safety": "npm run check:content-safety -w apps/server",
    "check:config": "npm run check:config -w apps/server",
    "check:frontend-secrets": "npm run check:frontend-secrets -w apps/mobile",
    "check:image-storage": "npm run check:image-storage -w apps/server",
    "check:permissions": "npm run check:permissions -w apps/mobile",
    "check:release-env": "npm run check:release-env -w apps/mobile",
    "check:tracking-sdk": "npm run check:tracking-sdk -w apps/mobile",
    "cleanup:expired-images": "npm run cleanup:expired-images -w apps/server",
    "prisma:validate": "npm run prisma:validate -w apps/server",
    "prisma:migrate": "npm run prisma:migrate -w apps/server",
    "smoke:api": "npm run smoke:api -w apps/server",
    "smoke:ui": "npm run smoke:ui -w apps/mobile",
    "preview": "npm run preview -w apps/mobile"
  }
}
