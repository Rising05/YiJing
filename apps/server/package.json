{
  "name": "@memory-palace/server",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/apps/server/src/main.js",
    "check:ai-templates": "node scripts/check-ai-templates.mjs",
    "check:content-safety": "node scripts/check-content-safety.mjs",
    "check:config": "node scripts/check-runtime-config.mjs",
    "check:cors-config": "node scripts/check-cors-config.mjs",
    "check:error-codes": "node scripts/check-error-codes.mjs",
    "check:image-storage": "node scripts/check-image-storage.mjs",
    "check:image-prompts": "node scripts/check-image-prompts.mjs",
    "check:ai-retry": "node scripts/check-ai-retry.mjs",
    "check:production-config": "node scripts/check-production-config-rules.mjs",
    "check:production-redaction": "node scripts/check-production-redaction.mjs",
    "cleanup:expired-images": "node scripts/cleanup-expired-images.mjs",
    "smoke:api": "node scripts/smoke-api.mjs",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/client": "^6.11.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "prisma": "^6.11.1",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
