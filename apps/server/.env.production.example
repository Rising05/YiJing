DATABASE_URL="mysql://user:password@mysql-host:3306/yijing"
JWT_SECRET="replace-with-a-real-random-secret-at-least-32-characters"
PORT=3000
NODE_ENV="production"
ALLOWED_ORIGINS="https://app.example.com,capacitor://localhost,ionic://localhost"

# Keep `none` until SMS and WeChat providers are actually implemented and verified.
# When enabling formal login, use `sms`, `wechat`, or `sms,wechat`.
AUTH_FORMAL_PROVIDERS="none"
SMS_PROVIDER=""
SMS_ENDPOINT=""
SMS_ACCESS_KEY_ID=""
SMS_ACCESS_KEY_SECRET=""
SMS_SIGN_NAME=""
SMS_TEMPLATE_CODE=""
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
WECHAT_UNIVERSAL_LINK=""

AI_MOCK_MODE="false"
LLM_BASE_URL="https://api.deepseek.com/v1"
LLM_API_KEY="replace-with-real-llm-api-key"
LLM_MODEL="deepseek-chat"
LLM_JSON_RETRY_COUNT=1
LLM_REQUEST_TIMEOUT_MS=30000

IMAGE_MOCK_MODE="false"
WANX_BASE_URL="https://dashscope.aliyuncs.com"
WANX_API_KEY="replace-with-real-dashscope-api-key"
WANX_MODEL="wan2.6-t2i"
WANX_SIZE="960*1696"
WANX_REQUEST_TIMEOUT_MS=120000

# Choose one provider for production image persistence.
# local is acceptable for a single-server MVP if PUBLIC_BASE_URL is an https domain.
# For multi-server or CDN delivery, prefer oss or s3-compatible.
STORAGE_PROVIDER="local"
LOCAL_STORAGE_DIR="uploads/generated-images"
PUBLIC_BASE_URL="https://api.example.com"

OSS_BUCKET=""
OSS_REGION=""
OSS_ENDPOINT=""
OSS_PUBLIC_BASE_URL=""
OSS_OBJECT_PREFIX="generated-images"
OSS_ACCESS_KEY_ID=""
OSS_ACCESS_KEY_SECRET=""

S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT=""
S3_PUBLIC_BASE_URL=""
S3_OBJECT_PREFIX="generated-images"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
