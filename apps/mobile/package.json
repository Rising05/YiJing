{
  "name": "@memory-palace/mobile",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:android:debug": "npm run build && npm run cap:sync:android && ./android/gradlew -p android assembleDebug",
    "build:android:release": "npm run build && npm run cap:sync:android && ./android/gradlew -p android assembleRelease bundleRelease",
    "build:ios:simulator": "npm run build && npm run cap:sync:ios && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' -derivedDataPath /tmp/yijing-derived-data CODE_SIGNING_ALLOWED=NO build",
    "check:android-release-config": "node scripts/check-android-release-config.mjs",
    "check:compliance-copy": "node scripts/check-compliance-copy.mjs",
    "check:frontend-secrets": "node scripts/check-frontend-secrets.mjs",
    "check:mobile-layout": "node scripts/check-mobile-layout.mjs",
    "check:mobile-runtime-config": "node scripts/check-mobile-runtime-config.mjs",
    "check:permissions": "node scripts/check-permissions.mjs",
    "check:release-metadata": "node scripts/check-release-metadata.mjs",
    "check:release-env": "node scripts/check-release-env.mjs",
    "check:tracking-sdk": "node scripts/check-tracking-sdk.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "cap:sync:android": "cap sync android",
    "cap:sync:ios": "cap sync ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.7",
    "@capacitor/core": "^7.6.7",
    "@capacitor/ios": "^7.6.7",
    "@capacitor/share": "^7.0.2",
    "@memory-palace/prompts": "0.1.0",
    "@memory-palace/shared": "0.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "framer-motion": "^12.23.0",
    "html-to-image": "^1.11.13",
    "liquid-glass-react": "^1.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.7",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.4.19"
  }
}
